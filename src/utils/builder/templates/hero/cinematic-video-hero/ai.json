{
  "name": "Cinematic Video Hero",
  "description": "High-fidelity video background with glassmorphism overlays and motion engineering.",
  "industry_relevance": ["technology", "modern", "agency", "luxury"],
  "prompt_context": "High-fidelity video background with glassmorphism overlays and motion engineering.",
  "image_hints": "Select an immersive, abstract cinematic video background that feels next-gen.",
  "content_schema": {
    "h1": "string (Main Headline, e.g. REDEFINING THE FUTURE.)",
    "description": "string (Sub-headline, e.g. Experience the next generation of digital excellence...)",
    "video_url": "string (Background Video URL)",
    "cta_primary": "string (Primary Button Text)",
    "cta_secondary": "string (Secondary Button Text)"
  },
  "settings_schema": [
    { "id": "overlay_opacity", "label": "Overlay Intensity", "type": "range", "min": 0, "max": 100, "default": 40 },
    { "id": "enable_blur_div", "label": "Glass Container", "type": "boolean", "default": true },
    { "id": "blur_intensity", "label": "Glass Blur Level", "type": "range", "min": 0, "max": 40, "default": 20 },
    { "id": "hero_text_size", "label": "Headline Size", "type": "select", "options": ["text-5xl md:text-6xl", "text-6xl md:text-8xl", "text-7xl md:text-9xl", "text-8xl md:text-[8.5rem]"], "default": "text-6xl md:text-8xl" },
    { "id": "hero_text_margin", "label": "Headline Margin Bottom", "type": "select", "options": ["mb-0", "mb-4", "mb-8", "mb-12", "mb-16"], "default": "mb-8" },
    { "id": "hero_text_alignment", "label": "Text Alignment", "type": "select", "options": ["text-left", "text-center", "text-right"], "default": "text-center" },
    { "id": "motion_speed", "label": "Motion Speed", "type": "range", "min": 0.5, "max": 2, "step": 0.1, "default": 1 },
    { "id": "show_scroll_indicator", "label": "Show Scroll Hint", "type": "boolean", "default": true },
    { "id": "container_animation", "label": "Container Animation", "type": "select", "options": ["fade-up", "scale-up", "blur-in", "3d-flip", "elastic-pop", "slide-right", "none"], "default": "fade-up" },
    { "id": "text_animation", "label": "Text Entry Animation", "type": "select", "options": ["slide-up", "fade", "scale", "spring-up", "blur-reveal", "flip-down", "none"], "default": "slide-up" }
  ]
}
